{
  "env": {
    "PATH": "$(PATH):$(HOME)/.local/bin"
  },
  "apps": [
    {
      "name": "Desktop",
      "image-path": "desktop.png"
    },
    {
      "name": "Low Res Desktop",
      "image-path": "desktop.png",
      "prep-cmd": [
        {
          "do": "xrandr --output {{XRANDR_OUTPUT_NAME}} --mode 1920x1080",
          "undo": "xrandr --output {{XRANDR_OUTPUT_NAME}} --mode 1920x1080"
        }
      ]
    },
    {
      "name": "Steam Big Picture",
      "detached": [
        "{{GAMING_STATION_STEAM_SCRIPT_PATH}} open-bigpicture"
      ],
      "prep-cmd": [
        {
          "do": "xrandr --output {{XRANDR_OUTPUT_NAME}} --mode 1920x1080",
          "undo": "{{GAMING_STATION_STEAM_SCRIPT_PATH}} close-bigpicture; xrandr --output {{XRANDR_OUTPUT_NAME}} --mode 1920x1080"
        }
      ],
      "image-path": "steam.png"
    }
  ]
}
